{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PromptDatasetEntry",
  "type": "object",
  "required": [
    "id", "version", "category", "subcategory", "title", "slug",
    "language", "difficulty", "audience", "use_case", "industry",
    "style", "tech_stack", "prompt", "negative_prompt",
    "acceptance_criteria", "tags", "website_card", "quality",
    "created_by_agent", "batch"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^PRM-[0-9]{6}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "category": {
      "type": "string",
      "enum": [
        "landing_pages", "ui_components", "saas_dashboards", "ecommerce",
        "portfolio_personal_brand", "ai_tools_agents", "education_learning",
        "mobile_apps", "games_interactive", "data_visualization"
      ]
    },
    "subcategory": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 120
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "language": {
      "type": "string",
      "enum": ["en", "de"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "expert"]
    },
    "audience": {
      "type": "string",
      "enum": [
        "frontend_developer", "fullstack_developer", "designer",
        "product_designer", "founder", "marketer", "teacher",
        "content_creator", "ai_builder", "game_developer"
      ]
    },
    "use_case": {
      "type": "string",
      "enum": [
        "website_generation", "component_generation", "app_generation",
        "dashboard_generation", "design_system_generation",
        "animation_generation", "copywriting_plus_ui", "educational_interface",
        "game_ui_generation", "data_visualization"
      ]
    },
    "industry": {
      "type": "string",
      "minLength": 1
    },
    "style": {
      "type": "object",
      "required": [
        "visual_style", "layout_style", "color_direction", "motion_style"
      ],
      "properties": {
        "visual_style": { "type": "string", "minLength": 5 },
        "layout_style": { "type": "string", "minLength": 5 },
        "color_direction": { "type": "string", "minLength": 5 },
        "motion_style": { "type": "string", "minLength": 5 }
      }
    },
    "tech_stack": {
      "type": "object",
      "required": ["framework", "language", "styling"],
      "properties": {
        "framework": { "type": "string" },
        "language": { "type": "string" },
        "styling": { "type": "string" },
        "animation": { "type": "string" },
        "optional_libraries": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "prompt": {
      "type": "string",
      "minLength": 50
    },
    "negative_prompt": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 10 },
      "minItems": 3,
      "maxItems": 6
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
      },
      "minItems": 5,
      "maxItems": 12
    },
    "website_card": {
      "type": "object",
      "required": ["headline", "summary", "preview_label", "search_keywords"],
      "properties": {
        "headline": { "type": "string", "minLength": 5 },
        "summary": { "type": "string", "minLength": 20 },
        "preview_label": { "type": "string", "minLength": 2 },
        "search_keywords": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "quality": {
      "type": "object",
      "required": [
        "specificity_score", "originality_score",
        "implementation_clarity_score", "website_readiness_score"
      ],
      "properties": {
        "specificity_score": { "type": "integer", "minimum": 1, "maximum": 10 },
        "originality_score": { "type": "integer", "minimum": 1, "maximum": 10 },
        "implementation_clarity_score": { "type": "integer", "minimum": 1, "maximum": 10 },
        "website_readiness_score": { "type": "integer", "minimum": 1, "maximum": 10 }
      }
    },
    "created_by_agent": { "type": "string" },
    "batch": { "type": "string" }
  }
}
